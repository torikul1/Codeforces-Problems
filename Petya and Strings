#include <iostream>
#include <string.h>
#include <stdio.h>
#include <bits/stdc++.h>
#include <ctype.h>
using namespace std;

int main()
{

    string word1, word2;
    cin >> word1 >> word2;

    int d = word1.length();

    int a = 0;
    for (int i = 0; i < d; i++)
    {
        char b = tolower(word1[i]);
        char c = tolower(word2[i]);
        if (b == c)
        {
            a = a + 1;
        }
        else if (b < c)
        {
            cout << "-1";
            return 0;
        }
        else if (b > c)
        {
            cout << "1";
            return 0;
        }
    }

    if (a == d)
    {
        cout << "0";
    }

    return 0;
}
